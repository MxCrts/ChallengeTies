{
  "expo": {
    "name": "ChallengeTies",
    "slug": "ChallengeMe",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1120"
    },
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "buildNumber": "47",
      "bundleIdentifier": "com.mxcrts.ChallengeTies",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:challengeties.app",
        "applinks:www.challengeties.app",
        "applinks:links.challengeties.app"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "LSApplicationQueriesSchemes": [
          "myapp",
          "itms-apps",
          "itms"
        ],
        "GADApplicationIdentifier": "ca-app-pub-4725616526467159~9688398116",
        "NSUserTrackingUsageDescription": "Votre identifiant peut etre utilise pour des publicites plus pertinentes afin de soutenir l'app.",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork"
          }
        ],
        "NSPhotoLibraryUsageDescription": "Nous avons besoin d'acceder a votre phototheque pour choisir une photo de profil.",
        "NSCameraUsageDescription": "Nous avons besoin d'acceder a la camera pour prendre une photo de profil.",
        "NSPhotoLibraryAddUsageDescription": "Autorisez l'ajout de photos pour enregistrer votre image de profil et votre carte de parrainage.",
        "NSLocationWhenInUseUsageDescription": "Nous utilisons votre position pour afficher du contenu et des defis proches de vous.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Nous utilisons votre position pour ameliorer votre experience, meme quand l'app est en arriere-plan.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0B1120"
      },
      "versionCode": 2,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.mxcrts.ChallengeTies",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "com.google.android.c2dm.permission.RECEIVE",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.POST_NOTIFICATIONS",
        "com.android.vending.BILLING",
        "android.permission.CAMERA"
      ],
     "googleServicesFile": "./google-services.json",
"blockedPermissions": [
  "android.permission.READ_MEDIA_IMAGES",
  "android.permission.READ_MEDIA_VIDEO",
  "android.permission.READ_EXTERNAL_STORAGE",
  "android.permission.WRITE_EXTERNAL_STORAGE",
  "android.permission.RECORD_AUDIO",
  "android.permission.MODIFY_AUDIO_SETTINGS",
  "android.permission.ACCESS_COARSE_LOCATION",
  "android.permission.ACCESS_FINE_LOCATION",
  "android.permission.SYSTEM_ALERT_WINDOW"
],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "challengeties.app",
              "pathPrefix": "/challenge-details"
            },
            {
              "scheme": "https",
              "host": "challengeties.app",
              "pathPrefix": "/challenge"
            },
            {
              "scheme": "https",
              "host": "links.challengeties.app",
              "pathPrefix": "/i"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
